FROM node:20-alpine AS build
WORKDIR /app
COPY src/frontend/package.json ./
COPY src/frontend/package-lock.json* ./
RUN npm install
COPY src/frontend/ ./
RUN npm run build

FROM nginx:alpine
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
