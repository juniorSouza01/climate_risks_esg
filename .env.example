# Copie para .env e ajuste. .env é gitignored.

# --- Postgres local ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=climate_esg
PG_PASSWORD=changeme_local_only
PG_DB=climate_esg
DATABASE_URL=postgresql+psycopg://climate_esg:changeme_local_only@localhost:5432/climate_esg

# --- Data lake local (sem MinIO no MVP) ---
DATA_BRONZE=./data/bronze
DATA_SILVER=./data/silver
DATA_GOLD=./data/gold

# --- Prefect ---
PREFECT_API_URL=http://127.0.0.1:4200/api

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns

# --- ESGF / CMIP6 (OPCIONAL) ---
# Só é necessário se um nó ESGF exigir login p/ baixar um dataset. A maioria
# do CMIP6 é aberta (o download da F0 funcionou sem credencial). Para obter:
# registre uma conta OpenID em um nó ESGF (ex.: https://esgf-node.llnl.gov,
# CEDA, DKRZ) e use a URL OpenID + senha. Deixe vazio se não precisar.
ESGF_OPENID=
ESGF_PASSWORD=

# --- Fontes corporativas (OPCIONAL) ---
# brapi.dev = cotações/fundamentos/volatilidade da B3. SEM token o mercado
# vem vazio (a busca continua funcionando com as demais fontes). Token grátis:
# crie conta em https://brapi.dev e copie o token no painel.
BRAPI_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO
